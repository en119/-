<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>錢包對帳監督系統</title>
    <style>
        :root { --primary: #4a90e2; --income: #2ecc71; --expense: #e74c3c; --bg: #f4f7f6; }
        body { font-family: -apple-system, sans-serif; background: var(--bg); margin: 0; padding: 15px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 450px; background: white; border-radius: 20px; padding: 20px; box-shadow: 0 8px 20px rgba(0,0,0,0.08); }
        .header-msg { text-align: center; color: var(--expense); font-weight: bold; margin-bottom: 15px; font-size: 14px; border: 1px solid #ffcccc; padding: 8px; border-radius: 8px; background: #fff5f5; }
        .balance-board { background: #333; color: white; padding: 20px; border-radius: 15px; text-align: center; margin-bottom: 20px; }
        .balance-amount { font-size: 32px; font-weight: bold; margin: 5px 0; color: #f1c40f; }
        .init-section { background: #eee; padding: 10px; border-radius: 10px; margin-bottom: 15px; font-size: 14px; display: flex; align-items: center; justify-content: space-between; }
        .init-section input { width: 100px; padding: 5px; border-radius: 5px; border: 1px solid #ccc; text-align: right; }
        .input-group { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; }
        .full-width { grid-column: span 2; }
        input { padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; box-sizing: border-box; }
        button { padding: 12px; border: none; border-radius: 8px; font-size: 16px; font-weight: bold; cursor: pointer; color: white; transition: 0.2s; }
        .btn-income { background: var(--income); }
        .btn-expense { background: var(--expense); }
        .history { height: 250px; overflow-y: auto; border-top: 1px solid #eee; margin-top: 10px; }
        .item { display: flex; justify-content: space-between; padding: 10px 5px; border-bottom: 1px solid #f9f9f9; align-items: center; }
        .amount-text { font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="header-msg">⚠️ 系統已連線：請誠實記錄，我隨時會檢查喔！</div>

    <div class="balance-board">
        <div style="font-size:14px; opacity:0.8;">錢包理論餘額</div>
        <div class="balance-amount" id="currentBalance">$ 0</div>
    </div>

    <div class="init-section">
        <span>週初錢包金額：</span>
        <input type="number" id="startBalance" value="0" onchange="updateUI()" inputmode="decimal">
    </div>

    <div class="input-group">
        <input type="text" id="itemName" class="full-width" placeholder="品項 (例如：晚餐)">
        <input type="number" id="itemPrice" class="full-width" placeholder="金額" inputmode="decimal">
        <button class="btn-income" onclick="handleAdd('收入')">＋ 收入</button>
        <button class="btn-expense" onclick="handleAdd('支出')">－ 支出</button>
    </div>

    <div style="font-size:14px; font-weight:bold;">最近帳目 (同步中...)</div>
    <div id="historyList" class="history"></div>
</div>

<script>
    const G_FORM_URL = "https://docs.google.com/forms/u/0/d/e/1FAIpQLSdL0eLpcL1I9Hhu8FH7fds2jBIhRW2T_aRyE7tSnDA-_tAZpQ/formResponse";
    const ID_NAME = "entry.254688195";
    const ID_TYPE = "entry.166850842";
    const ID_PRICE = "entry.2093753088";

    let records = JSON.parse(localStorage.getItem('my_wallet_data') || '[]');
    let startAmount = parseFloat(localStorage.getItem('my_wallet_start') || '0');
    document.getElementById('startBalance').value = startAmount;
    updateUI();

    function handleAdd(type) {
        const name = document.getElementById('itemName').value;
        const price = document.getElementById('itemPrice').value;

        if (!name || !price) { alert("內容填完再按啦！"); return; }

        // 1. 同步到你的 Google 表單 (監督用)
        const formData = new URLSearchParams();
        formData.append(ID_NAME, name);
        formData.append(ID_TYPE, type);
        formData.append(ID_PRICE, price);

        fetch(G_FORM_URL, {
            method: "POST",
            mode: "no-cors",
            body: formData
        });

        // 2. 存在手機本地並更新畫面
        const newRecord = { name, price: parseFloat(price), type, date: new Date().toLocaleTimeString() };
        records.unshift(newRecord);
        localStorage.setItem('my_wallet_data', JSON.stringify(records));
        
        document.getElementById('itemName').value = '';
        document.getElementById('itemPrice').value = '';
        updateUI();
    }

    function updateUI() {
        startAmount = parseFloat(document.getElementById('startBalance').value) || 0;
        localStorage.setItem('my_wallet_start', startAmount);

        let totalIncome = 0;
        let totalExpense = 0;
        const listDiv = document.getElementById('historyList');

        listDiv.innerHTML = records.map(r => {
            if (r.type === '收入') totalIncome += r.price;
            else totalExpense += r.price;
            return `
                <div class="item">
                    <span>${r.name} <small style="color:#999">(${r.type})</small></span>
                    <span class="amount-text" style="color:${r.type==='收入'?'green':'red'}">
                        ${r.type==='收入'?'+':'-'}$${r.price}
                    </span>
                </div>`;
        }).join('');

        document.getElementById('currentBalance').innerText = `$ ${(startAmount + totalIncome - totalExpense).toLocaleString()}`;
    }
</script>
</body>
</html>
